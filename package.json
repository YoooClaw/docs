{
  "name": "@yoooclaw/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "yoooclaw 文档站：基于 VitePress 把项目文档构建为静态页面",
  "scripts": {
    "dev": "vitepress dev src",
    "build": "vitepress build src",
    "preview": "vitepress preview src",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "deploy": "bun run build && wrangler pages deploy src/.vitepress/dist --project-name developer-yoooclaw --branch master --commit-dirty=true"
  },
  "keywords": [
    "yoooclaw",
    "docs",
    "vitepress",
    "documentation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YoooClaw/docs.git"
  },
  "author": "developer@yoooclaw.com",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.93.0"
  }
}
